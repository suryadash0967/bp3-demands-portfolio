# ── FastAPI AI Service ────────────────────────────────────────────────
# Copy this file to ai/.env and fill in your values.

# Path to the Excel knowledge base (relative to ai/ directory)
EXCEL_PATH=../src/data/demands.xlsx

# ChromaDB persistent storage path
CHROMA_PATH=./chroma_store

# ChromaDB collection name
COLLECTION_NAME=bp3_demands

# Sentence-transformers model
EMBED_MODEL=all-MiniLM-L6-v2

# Number of documents to retrieve for RAG
TOP_K=8

# FastAPI service port
AI_PORT=8000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=20

# ── LLM Backend ─────────────────────────────────────────────────────
# Choose: "ollama" (free, local) or "openai" (cloud/compatible API)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
# Install: https://ollama.com | then: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI-compatible settings (used when LLM_BACKEND=openai)
# Works with OpenAI, Groq, Together AI, local vLLM, etc.
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
